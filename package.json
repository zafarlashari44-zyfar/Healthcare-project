{
  "name": "healthcare-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",  
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "supabase db push --linked",
    "db:types": "supabase gen types typescript --linked --schema public",
    "db:lint": "supabase db lint --linked --schema public,private --level warning --fail-on error",
    "db:migrations": "supabase migration list --linked",
    "user:set-role": "node --env-file=.env.local scripts/set-user-role.mjs",
    "ai:check": "node --env-file=.env.local scripts/check-ollama.mjs",
    "ai:test": "node --env-file=.env.local scripts/check-ollama.mjs --generate",
    "automation:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-n8n.ps1",
    "automation:check": "node --env-file=.env.local scripts/check-n8n.mjs",
    "automation:test": "node --env-file=.env.local scripts/check-n8n.mjs --webhook"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-navigation-menu": "^1.2.15",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-toast": "^1.2.16",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.108.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "supabase": "^2.106.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
